{
  "name": "@quantclaw/feishu",
  "version": "2026.3.30",
  "description": "QuantClaw Feishu/Lark channel plugin (community maintained by @m1heng)",
  "type": "module",
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "@sinclair/typebox": "0.34.49",
    "https-proxy-agent": "^8.0.0"
  },
  "devDependencies": {
    "quantclaw": "workspace:*"
  },
  "peerDependencies": {
    "quantclaw": ">=2026.3.30"
  },
  "peerDependenciesMeta": {
    "quantclaw": {
      "optional": true
    }
  },
  "quantclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "feishu",
      "label": "Feishu",
      "selectionLabel": "Feishu/Lark (飞书)",
      "docsPath": "/channels/feishu",
      "docsLabel": "feishu",
      "blurb": "飞书/Lark enterprise messaging with doc/wiki/drive tools.",
      "aliases": [
        "lark"
      ],
      "order": 35,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@quantclaw/feishu",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.3.30"
    },
    "bundle": {
      "stageRuntimeDependencies": true
    },
    "release": {
      "publishToNpm": true
    }
  }
}
