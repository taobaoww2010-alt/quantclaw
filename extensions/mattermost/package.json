{
  "name": "@quantclaw/mattermost",
  "version": "2026.3.30",
  "description": "QuantClaw Mattermost channel plugin",
  "type": "module",
  "dependencies": {
    "@sinclair/typebox": "0.34.49",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "quantclaw": "workspace:*"
  },
  "peerDependencies": {
    "quantclaw": ">=2026.3.30"
  },
  "peerDependenciesMeta": {
    "quantclaw": {
      "optional": true
    }
  },
  "quantclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "mattermost",
      "label": "Mattermost",
      "selectionLabel": "Mattermost (plugin)",
      "docsPath": "/channels/mattermost",
      "docsLabel": "mattermost",
      "blurb": "self-hosted Slack-style chat; install the plugin to enable.",
      "order": 65
    },
    "install": {
      "npmSpec": "@quantclaw/mattermost",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.3.30"
    }
  }
}
