{
  "name": "@quantclaw/nostr",
  "version": "2026.3.30",
  "description": "QuantClaw Nostr channel plugin for NIP-04 encrypted DMs",
  "type": "module",
  "dependencies": {
    "nostr-tools": "^2.23.3"
  },
  "devDependencies": {
    "quantclaw": "workspace:*"
  },
  "peerDependencies": {
    "quantclaw": ">=2026.3.30"
  },
  "peerDependenciesMeta": {
    "quantclaw": {
      "optional": true
    }
  },
  "quantclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "nostr",
      "label": "Nostr",
      "selectionLabel": "Nostr (NIP-04 DMs)",
      "docsPath": "/channels/nostr",
      "docsLabel": "nostr",
      "blurb": "Decentralized protocol; encrypted DMs via NIP-04.",
      "order": 55,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@quantclaw/nostr",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.3.30"
    },
    "release": {
      "publishToNpm": true
    }
  }
}
