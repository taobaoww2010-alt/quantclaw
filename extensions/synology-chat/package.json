{
  "name": "@quantclaw/synology-chat",
  "version": "2026.3.30",
  "description": "Synology Chat channel plugin for QuantClaw",
  "type": "module",
  "quantclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "synology-chat",
      "label": "Synology Chat",
      "selectionLabel": "Synology Chat (Webhook)",
      "docsPath": "/channels/synology-chat",
      "docsLabel": "synology-chat",
      "blurb": "Connect your Synology NAS Chat to QuantClaw with full agent capabilities.",
      "order": 90
    },
    "install": {
      "npmSpec": "@quantclaw/synology-chat",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.3.30"
    }
  }
}
